    "%lld reading%@ line up so far — not enough to read a trend yet (NOOP waits for %lld).": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld reading%2$@ line up so far — not enough to read a trend yet (NOOP waits for %3$lld)."
