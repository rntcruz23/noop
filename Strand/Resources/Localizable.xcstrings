            "value": "Home del progetto e codice sorgente su GitHub"
          }
        }
      }
    },
    "Proof that the console is current": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prova che la console è aggiornata"
          }
        }
      }
    },
    "Pulls your strap's stored history immediately, without waiting for the next automatic sync.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Recupera immediatamente la cronologia memorizzata nella tua fascia, senza aspettare la prossima sincronizzazione automatica."
          }
        }
      }
    },
    "Quick actions": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Azioni rapide"
          }
        }
      }
    },
    "QUICK ACTIONS": {
