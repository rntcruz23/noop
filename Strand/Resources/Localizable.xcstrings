      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Creazione in corso, 1 finestra"
          }
        }
      }
    },
    "Building your baseline. About %lld more %@ until your scores are personal.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Building your baseline. About %1$lld more %2$@ until your scores are personal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Creazione della tua linea di base. Ancora circa %1$lld %2$@ prima che i tuoi punteggi siano personalizzati."
          }
        }
      }
    },
    "Building your best-sourced record…": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Creazione del tuo record con le migliori sorgenti…"
          }
        }
      }
    },
    "Builds a redacted .zip, shows you exactly what it contains, then opens a prefilled GitHub issue. You attach the file on the next screen.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un file .zip oscurato, ti mostra esattamente cosa contiene, poi apre una issue GitHub precompilata. Allega il file nella schermata successiva."
          }
        }
      }
    },
    "Built from published methods (Nes/HUNT) on %@. It's a fitness comparison against an average peer your age — not a biological or medical age.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Calcolata con metodi pubblicati (Nes/HUNT) su %@. È un confronto di forma fisica con una persona media della tua età, non un'età biologica o medica."
          }
        }
      }
    },
    "Buzz Strap": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fai vibrare la fascia"
          }
        }
      }
    },
    "Buzz your strap or mark a moment from Siri, Spotlight, the Shortcuts app, or a Back-Tap / automation — no setup needed.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
