    "%lld readings line up, but there isn't enough variation to compute a relationship.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld letture si allineano, ma non c'è abbastanza variazione per calcolare una relazione."
