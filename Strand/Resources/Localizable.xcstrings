            "value": "Frequenza cardiaca di picco"
          }
        }
      }
    },
    "Per extra %@": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per %@ in più"
          }
        }
      }
    },
    "Per-night need": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fabbisogno per notte"
          }
        }
