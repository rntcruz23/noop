    "Every beat, every night, every day , woven into one quiet picture of you. Welcome to NOOP.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every beat, every night, every day , woven into one quiet picture of you. Welcome to NOOP."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeder Schlag, jede Nacht, jeder Tag , verwoben zu einem ruhigen Bild von dir. Willkommen bei NOOP."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждый удар сердца, каждая ночь, каждый день , всё складывается в цельную картину вашего состояния. Добро пожаловать в NOOP!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque battement, chaque nuit, chaque jour , tissé en un portrait silencieux de vous. Bienvenue dans NOOP."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada latido, cada noche, cada día, entrelazados en una imagen serena de ti. Bienvenido a NOOP."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni battito, ogni notte, ogni giorno, intrecciati in un quadro silenzioso di te. Benvenuto in NOOP."
          }
        }
      }
    },
    "Every session, threaded together.": {
      "localizations": {
