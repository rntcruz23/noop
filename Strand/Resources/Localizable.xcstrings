    },
    "%lld readings used · %@ %@ association. This is your own data sitting side by side — it's not a medical finding, and it shows association, not cause.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld readings used · %2$@ %3$@ association. This is your own data sitting side by side — it's not a medical finding, and it shows association, not cause."
          }
