            "state": "translated",
            "value": "Apprendimento"
          }
        }
      }
    },
    "Learning your baseline, %lld of %lld nights.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Learning your baseline, %1$lld of %2$lld nights."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apprendimento della tua linea di base, %1$lld di %2$lld notti."
          }
        }
      }
    },
    "Leave none active": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non lasciarne nessuna attiva"
          }
        }
      }
    },
    "Leftover import copies": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Copie di importazione residue"
          }
        }
      }
    },
    "Light + sleep timing only": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo leggero + tempistica del sonno"
          }
        }
      }
    },
    "Lining them up…": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Allineamento in corso…"
          }
        }
      }
    },
    "Live Body Console": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Console del corpo in diretta"
          }
        }
      }
    },
    "Live heart rate already works on a WHOOP 5/MG strap. These probes go further and try to coax more out of it. They are guesses, off by default, and only ever touch a 5/MG strap — WHOOP 4.0 is never affected.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La frequenza cardiaca in diretta funziona già su una fascia WHOOP 5/MG. Queste sonde vanno oltre e cercano di ricavarne di più. Sono ipotesi, disattivate per impostazione predefinita, e toccano solo una fascia 5/MG, WHOOP 4.0 non è mai interessato."
          }
        }
      }
    },
    "Live heart rate in Dynamic Island": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Frequenza cardiaca in diretta nella Dynamic Island"
          }
        }
      }
    },
    "Live heart rate over time": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Frequenza cardiaca in diretta nel tempo"
          }
        }
      }
    },
    "Live HR": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "FC in diretta"
          }
