    "Trends need history to draw. Import your WHOOP export in Data Sources to see weeks, months and years instantly.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Trends need history to draw. Import your WHOOP export in Data Sources to see weeks, months and years instantly."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Trends benötigen Verlauf zur Darstellung. Importiere deinen WHOOP-Export unter Datenquellen, um Wochen, Monate und Jahre sofort zu sehen."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для построения трендов нужна история. Импортируйте данные WHOOP в разделе «Источники данных», чтобы сразу увидеть данные за недели, месяцы и годы."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les tendances ont besoin d'historique pour s'afficher. Importez votre export WHOOP dans Sources de données pour voir semaines, mois et années instantanément."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tendencias necesitan historial para dibujarse. Importa tu exportación de WHOOP en Fuentes de datos para ver semanas, meses y años al instante."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli andamenti hanno bisogno di una cronologia per essere tracciati. Importa la tua esportazione WHOOP in Sorgenti dati per vedere subito settimane, mesi e anni."
          }
        }
      }
    },
