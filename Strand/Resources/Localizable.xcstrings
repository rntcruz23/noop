    "Bonded — streaming.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Associata, in streaming."
          }
        }
      }
    },
    "Both NOOP and the Oura app can use a ring you own by key, but only one can hold the Bluetooth link at a time.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
